# ==============================================
# Environment Variables
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=microservices-assignment
ENVIRONMENT=development

# --- Database credentials (Docker Compose MySQL containers) ---
DB_USER=
MYSQL_ROOT_PASSWORD=
MENU_DB_PASSWORD=
CART_DB_PASSWORD=
ORDER_DB_PASSWORD=
PAYMENT_DB_PASSWORD=

# --- Optional defaults for local non-Docker runs ---
DB_HOST=
DB_PORT=
DB_NAME=

# --- Service Ports ---
MENU_SERVICE_PORT=
CART_SERVICE_PORT=
ORDER_SERVICE_PORT=
PAYMENT_SERVICE_PORT=
TASK_SERVICE_PORT=
GATEWAY_PORT=
FRONTEND_PORT=

# --- Inter-service URLs ---
CART_SERVICE_URL=
ORDER_SERVICE_URL=
PAYMENT_SERVICE_URL=

# --- API Gateway ---
GATEWAY_SECRET=
