# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=microservices-assignment
ENVIRONMENT=development

# --- Database credentials (used by menu/cart/order/payment DB containers) ---
DB_USER=admin
DB_ROOT_PASSWORD=rootchangeme
MENU_DB_PASSWORD=menuchangeme
CART_DB_PASSWORD=cartchangeme
ORDER_DB_PASSWORD=orderchangeme
PAYMENT_DB_PASSWORD=paymentchangeme

# Optional defaults for local non-Docker runs
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mydb

# --- Service Ports ---
MENU_SERVICE_PORT=5001
CART_SERVICE_PORT=5002
ORDER_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
TASK_SERVICE_PORT=5005
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- API Gateway ---
GATEWAY_SECRET=your-gateway-secret

# --- Add more variables as needed for your stack ---
# REDIS_URL=redis://localhost:6379
# RABBITMQ_URL=amqp://localhost:5672
# JWT_SECRET=your-jwt-secret
